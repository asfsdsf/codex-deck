{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@codex-deck/wire": ["./wire/src/index.ts"]
    },
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./api"
  },
  "include": ["api/**/*"],
  "exclude": ["node_modules", "dist", "web"]
}
